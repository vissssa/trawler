{
  "name": "trawler",
  "version": "1.0.0",
  "description": "面向大模型知识库的网页爬取API服务。",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "tsc",
    "dev:api": "nodemon --exec ts-node src/api/server.ts",
    "dev:worker": "nodemon --exec ts-node src/worker/consumer.ts",
    "dev:scheduler": "nodemon --exec ts-node src/scheduler/index.ts",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/worker/consumer.js",
    "start:scheduler": "node dist/scheduler/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^9.4.0",
    "bullmq": "^5.68.0",
    "cheerio": "^1.2.0",
    "crawlee": "^3.16.0",
    "dotenv": "^17.2.4",
    "fastify": "^5.7.4",
    "ioredis": "^5.9.2",
    "mongoose": "^9.2.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.58.2",
    "redlock": "^5.0.0-beta.2"
  },
  "devDependencies": {
    "@types/cheerio": "^0.22.35",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
